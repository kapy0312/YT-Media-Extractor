{
  "name": "yt-dip",
  "version": "1.0.0",
  "type": "module",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "build": {
    "appId": "com.kevin.ytdownloader",
    "productName": "YT Audio Extractor",
    "mac": {
      "target": "dmg",
      "category": "public.app-category.utilities"
    },
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "asarUnpack": [
      "**/node_modules/ffmpeg-static/**/*"
    ],
    "files": [
      "main.js",
      "server.js",
      "public/**/*"
    ]
  },
  "dependencies": {
    "express": "^4.21.2",
    "ffmpeg-static": "^5.2.0",
    "socket.io": "^4.8.3",
    "yt-dlp-wrap": "^2.3.12"
  },
  "devDependencies": {
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1"
  }
}
