{
  "name": "yt-media-extractor",
  "version": "2.5.6",
  "description": "YouTube Media Extractor Tool",
  "author": "YourName",
  "type": "module",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "build": {
    "appId": "com.kevin.ytdownloader",
    "productName": "YT-Media-Extractor",
    "mac": {
      "target": "dmg",
      "category": "public.app-category.utilities"
    },
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "asarUnpack": [
      "**/node_modules/ffmpeg-static/**/*"
    ],
    "files": [
      "main.js",
      "server.js",
      "preload.cjs",
      "public/**/*"
    ]
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "electron-log": "^5.4.3",
    "ffmpeg-static": "^5.2.0",
    "yt-dlp-wrap": "^2.3.12"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  }
}
